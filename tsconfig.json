{
    "compilerOptions": {
        "allowJs": true,
        "noEmit": true,
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./resources/js/*"]
        }
    },
    "include": [
        "resources/js/**/*"
    ],
    "exclude": ["node_modules", "public", "vendor"]
}